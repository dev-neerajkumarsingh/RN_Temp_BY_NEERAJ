# pnpm: install a flat, hoisted node_modules.
#
# React Native's Android Gradle plugin, iOS autolinking scripts, Metro, and
# several native libraries resolve paths via literal `node_modules/<pkg>`
# lookups that don't follow pnpm's isolated symlink store. Without this,
# builds fail with errors like:
#   "Included build 'node_modules/@react-native/gradle-plugin' does not exist"
node-linker=hoisted
